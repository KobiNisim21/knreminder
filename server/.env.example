# ─── Server ───────────────────────────────────────────────
# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/kn-reminder?retryWrites=true&w=majority

# ─── Telegram Bot ─────────────────────────────────────────
# Step 1: Message @BotFather on Telegram → /newbot → copy token below
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Step 2: Message your new bot (/start), then visit:
#   https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# Find "message" → "chat" → "id" and paste it below
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ─── App ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS — update to your Vercel domain in production)
CLIENT_URL=http://localhost:5173

# Your server's public URL (needed to register Telegram webhook on deploy)
# Example: https://kn-reminder.railway.app
SERVER_URL=http://localhost:5000

# Timezone for formatting notification messages
TZ=Asia/Jerusalem
