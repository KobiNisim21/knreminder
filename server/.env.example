# ─── Server ───────────────────────────────────────────────
# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/kn-reminder?retryWrites=true&w=majority

# ─── Telegram Bot ─────────────────────────────────────────
# Step 1: Message @BotFather on Telegram → /newbot → copy token below
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Step 2: Message your new bot (/start), then visit:
#   https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# Find "message" → "chat" → "id" and paste it below.
#
# NOTE (multi-user): As of the multi-user release, each reminder stores its own
# owner chatId and notifications route per-user. TELEGRAM_CHAT_ID is now only a
# LOCAL-DEV FALLBACK — it seeds the owner for docs/requests that arrive without
# an identity. It is IGNORED as an auth fallback when NODE_ENV=production, where
# users must authenticate via the Telegram Login Widget instead.
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Telegram Login Widget: the bot's @username (no @). Required for production
# login. Set the same value in the client as VITE_TELEGRAM_BOT_USERNAME.
# Configure your login domain via @BotFather → /setdomain.
TELEGRAM_BOT_USERNAME=your_bot_username

# ─── App ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS — update to your Vercel domain in production)
CLIENT_URL=http://localhost:5173

# Your server's public URL (needed to register Telegram webhook on deploy)
# Example: https://kn-reminder.railway.app
SERVER_URL=http://localhost:5000

# Timezone for formatting notification messages
TZ=Asia/Jerusalem
