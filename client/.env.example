# ─── Client (Vite) ────────────────────────────────────────
# Backend API base URL.
#   Dev:  http://localhost:5000
#   Prod: your Railway/Render URL, e.g. https://kn-reminder.railway.app
VITE_API_URL=http://localhost:5000

# Telegram bot @username (no @) for the Telegram Login Widget on the login screen.
# Must match TELEGRAM_BOT_USERNAME on the server. When empty, the login screen
# falls back to manual Chat ID entry (dev only — the server rejects it in prod).
VITE_TELEGRAM_BOT_USERNAME=your_bot_username
